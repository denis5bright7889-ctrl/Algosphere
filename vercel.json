{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "turbo run build --filter=@ai-trading-hub/web",
  "installCommand": "npm install",
  "outputDirectory": "apps/web/.next",
  "git": {
    "deploymentEnabled": true
  },
  "crons": [
    { "path": "/api/cron/daily-content",  "schedule": "0 6 * * *" },
    { "path": "/api/cron/growth-publish", "schedule": "0 9 * * *" }
  ]
}
