{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Node",
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "strict": true,
    "skipLibCheck": true,
    "lib": ["dom", "es2020"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "public/**/*.json"]
}
