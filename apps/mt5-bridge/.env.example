# ── AlgoSphere MT5 Bridge — environment ───────────────────────────────
#
# Copy to .env (or set as Windows env vars) and fill in.

# ── Required ──────────────────────────────────────────────────────────

# Shared secret with the Railway engine. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# MUST equal MT5_BRIDGE_API_KEY on the Railway side.
BRIDGE_API_KEY=

# ── Single-account mode (optional but recommended for production) ─────
#
# When set, the bridge:
#   • Enables the watchdog (pings MT5 every 30s, surfaces state in /health)
#   • Exposes GET /account and GET /positions (no body required)
#   • Backs POST /trade/place and POST /trade/close
#
# When unset, the bridge stays in pure multi-tenant mode: only the
# POST endpoints that accept login/password/server in the body work.
# The Railway engine's MT5BridgeAdapter uses that path either way.

MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=

# If true, the first /connect call pins the terminal to that account
# and subsequent calls skip the re-login (faster, single-account).
# Leave false for multi-user shared-bridge setups.
MT5_PIN_LOGIN=false

# ── Safety guardrails (last-line-of-defense — engine has full risk stack) ──

# Reject any order whose lot size exceeds this hard cap, regardless of
# what the broker's max_lot says.
MAX_LOT_LIMIT=100.0

# Reject any order whose symbol isn't in this comma-separated list.
# Leave empty to allow all symbols.
SYMBOL_WHITELIST=

# Per-bridge rolling 60-second cap on order submissions.
MAX_ORDERS_PER_MIN=30

# ── Watchdog tuning (only meaningful when MT5_LOGIN is set) ────────────

WATCHDOG_INTERVAL_S=30
WATCHDOG_MAX_FAILURES=3

# ── Logging ────────────────────────────────────────────────────────────

# Directory for rotating mt5bridge.log file. Created if missing.
LOG_DIR=logs
