# =============================================================================
# AI Trading Hub — Web App Environment Variables
# Copy to .env.local and fill in required values
# =============================================================================

# --- Supabase (REQUIRED) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Binance USDT TRC20 (REQUIRED for payments) ---
BINANCE_PAYMENT_ENABLED=true
BINANCE_USDT_TRC20_ADDRESS=your-trc20-wallet-address

# --- Payment provider setting ---
PAYMENT_PROVIDER=BINANCE
PAYMENT_NETWORK=TRC20
PAYMENT_TOKEN=USDT

# --- Admin ---
ADMIN_EMAIL=your-admin-email@example.com

# --- App URL ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# DISABLED PROVIDERS — safe to leave empty, app will not crash
# =============================================================================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_PREMIUM_PRICE_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_WEBHOOK_HASH=
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
RESEND_API_KEY=
NEXTAUTH_SECRET=
